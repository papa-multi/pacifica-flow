[Unit]
Description=Pacifica Wallet Explorer v3 Canonical Refresh
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/root/pacifica-flow
EnvironmentFile=-/root/pacifica-flow/config/runtime.env
ExecStart=/bin/bash /root/pacifica-flow/scripts/systemd/run_wallet_explorer_v3_refresh.sh
Nice=5
IOSchedulingClass=best-effort
IOSchedulingPriority=7
